// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

// Модел за Каталога с Къщи
model House {
  id               String   @id @default(cuid())
  name             String
  area             Float    // Квадратура
  bedrooms         Int      // Брой спални
  bathrooms        Int      // Брой бани
  toilets          Int      @default(1) // Брой тоалетни
  floors           Int      @default(1) // Етажи
  terraces         Int      @default(0) // Тераси
  price            String   // Цена (съхраняваме я като чист низ "250000")
  description      String?  @db.Text
  imageUrl         String?  // Път към главната снимка
  gallery          String[] // Галерия от допълнителни снимки
  tags             String[] // Тагове (напр. ["Енергоефективна", "Премиум"])

  // ТЕХНИЧЕСКИ ХАРАКТЕРИСТИКИ
  constructionType String?  // Вид конструкция (напр. "Масивна метална")
  profileSize      String?  // Размери на профилите (напр. "100х100х5 мм")
  wallThickness    String?  // Дебелина на стената (напр. "25 см")
  wallTech         String?  // Технология на стената (напр. "Дишаща система БИОЗИД")
  roofType         String?  // Вид покрив (напр. "Двускатен / Плосък")
  windowsType      String?  // Вид дограма (напр. "7-камерна PVC, троен стъклопакет")

  createdAt        DateTime @default(now())
  // ЗАЩИТА: Добавяме default(now()), за да не гърми при съществуващи записи
  updatedAt        DateTime @default(now()) @updatedAt
}

// Модел за Клиентските заявки от Калкулатора
model QuoteRequest {
  id            String   @id @default(cuid())
  clientName    String
  clientPhone   String
  totalArea     Float
  status        String   @default("new") // new, in_progress, completed
  underlayUrl   String?  // Линк към качената подложка (чертеж)
  cadData       Json?    // Тук пазим целия масив със стени и панели за CAD редактора
  
  // --- НОВО: ПОЛЕ ЗА СЛУЖЕБНИЯ ПАНЕЛ (ЕТАЖИ И ПОДЛОЖКИ) ---
  floorsData    Json?    // Тук пазим масива с етажите, ppm мащаба и специфичните подложки за всеки етаж
  
  createdAt     DateTime @default(now())
  // ЗАЩИТА: Добавяме default(now()), за да не гърми при съществуващи записи
  updatedAt     DateTime @default(now()) @updatedAt
}